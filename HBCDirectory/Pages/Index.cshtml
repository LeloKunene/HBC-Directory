@page "Index"
@model IndexModel

@{
    var groupedMembers = Model.Members
        .Where(m => m.FamilyId != null && m.Family != null)
        .GroupBy(m => m.FamilyId)
        .OrderBy(g => g.First().Family!.FamilyName)
        .ToList();

    var unassignedMembers = Model.Members
        .Where(m => m.FamilyId == null)
        .ToList();
}

<h2 class="page-title">Church Directory</h2>
<form method="get" class="d-flex gap-2 mb-4 align-items-center flex-wrap" role="search">

    <div class="search-bar-wrap">
        <input asp-for="q" class="form-control search-bar" placeholder="Search by name or surname" />
        <button type="submit" class="search-icon-btn" aria-label="Search">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
    </div>
    <div class="select-wrap">
        <select asp-for="familyId" class="form-select">
            <option class="form-select" value="">All families</option>
            @foreach (var f in Model.Families)
            {
                <option value="@f.Id">@f.FamilyName</option>
            }
        </select>
    </div>
    <div class="select-wrap">
        <select asp-for="role" class="form-select">
            <option value="">All roles</option>
            @foreach (var r in new[] { "Elder", "Deacon" })
            {
                <option value="@r">@r</option>
            }
        </select>
    </div>
    @{
        var upcomingCount = Model.UpcomingBirthdays.Count + Model.UpcomingAnniversaries.Count;
    }
    <button type="button" class="upcoming-icon-btn" data-bs-toggle="offcanvas" data-bs-target="#upcomingOffcanvas"
            aria-controls="upcomingOffcanvas" aria-label="Upcoming birthdays and anniversaries">
        <i class="fa-solid fa-bell"></i>
        @if (upcomingCount > 0)
        {
            <span class="upcoming-count-badge">@upcomingCount</span>
        }
    </button>
</form>


<div class="offcanvas offcanvas-end upcoming-offcanvas" tabindex="-1" id="upcomingOffcanvas" aria-labelledby="upcomingOffcanvasLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="upcomingOffcanvasLabel">Upcoming Dates</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <h6 class="upcoming-modal-heading">Birthdays <span class="text-muted small">(next 30 days)</span></h6>
        @if (Model.UpcomingBirthdays.Any())
        {
            <ul class="upcoming-list">
                @foreach (var m in Model.UpcomingBirthdays)
                {
                    <li class="upcoming-list-item">
                        <span>@m.Name @m.Surname</span>
                        <span class="upcoming-date">@m.Birthdate!.Value.ToString("MMMM d")</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">None in the next 30 days</p>
        }

        <h6 class="upcoming-modal-heading mt-4">Anniversaries <span class="text-muted small">(next 30 days)</span></h6>
        @if (Model.UpcomingAnniversaries.Any())
        {
            <ul class="upcoming-list">
                @foreach (var m in Model.UpcomingAnniversaries)
                {
                    <li class="upcoming-list-item">
                        <span>@m.Name @m.Surname</span>
                        <span class="upcoming-date">@m.Anniversary!.Value.ToString("MMMM d")</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">None in the next 30 days</p>
        }
    </div>
</div>
@if (!Model.Members.Any() && (!string.IsNullOrEmpty(Model.q) || Model.familyId.HasValue ||
!string.IsNullOrEmpty(Model.role)))
{
    <div class="empty-state">
        <i class="fa-solid fa-magnifying-glass"></i>
        <p>No members found matching your search.</p>
        <a asp-page="/Index" class="btn btn-outline-primary">Clear search</a>
    </div>
}
else
{
    @foreach (var group in groupedMembers)
    {
        var family = group.First().Family!;
        <div class="family-group">
            <div class="family-group-header">
                @if (family.PhotoFileName != null)
                {
                    <div class="family-group-photo family-group-photo--clickable" data-bs-toggle="modal"
                         data-bs-target="#family-modal-@family.Id">
                        <img src="@Model.PhotoUrl(family.PhotoFileName)" alt="@family.FamilyName family photo" />
                    </div>
                }
                else
                {
                    <div class="family-group-photo">
                        <i class="fa-solid fa-people-roof" ></i>
                    </div>
                }
                <h3 class="family-group-name">@family.FamilyName</h3>
            </div>

            <ul class="member-list member-list--index">
                @foreach (var m in group.OrderBy(m => m.Surname).ThenBy(m => m.Name))
                {
                    @await Html.PartialAsync("_MemberCard", m)
                }
            </ul>
        </div>

        @if (family.PhotoFileName != null)
        {
            <div class="modal fade family-photo-modal" id="family-modal-@family.Id" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@family.FamilyName</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <img src="@Model.PhotoUrl(family.PhotoFileName)" alt="@family.FamilyName family photo"
                                 class="family-photo-full" />
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (unassignedMembers.Any())
    {
        <div class="family-group family-group--unassigned">
            <div class="family-group-header">
                <div class="family-group-photo family-group-photo--unassigned">
                    <i class="fa-solid fa-user-group"></i>
                </div>
                <h3 class="family-group-name">Unassigned</h3>
            </div>

            <ul class="member-list member-list--index">
                @foreach (var m in unassignedMembers.OrderBy(m => m.Surname).ThenBy(m => m.Name))
                {
                    @await Html.PartialAsync("_MemberCard", m)
                }
            </ul>
        </div>
    }
}