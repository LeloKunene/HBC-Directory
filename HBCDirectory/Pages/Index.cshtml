@page "Index"
@model IndexModel
@{
    ViewData["Title"] = "Directory";
}

<h2 class="page-title">Church Directory</h2>
<form method="get" class="d-flex gap-2 mb-4 align-items-center flex-wrap" role="search">

    <div class="search-bar-wrap">
        <input asp-for="q" class="form-control search-bar" placeholder="Search by name or surname" />
        <button type="submit" class="search-icon-btn" aria-label="Search">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
    </div>
    <div class="select-wrap">
        <select asp-for="familyId" class="form-select">
            <option class="form-select" value="">All families</option>
            @foreach (var f in Model.Families)
            {
                <option value="@f.Id">@f.FamilyName</option>
            }
        </select>
    </div>
</form>

@if (!Model.Members.Any() && (!string.IsNullOrEmpty(Model.q) || Model.familyId.HasValue))
{
    <div class="empty-state">
        <i class="fa-solid fa-magnifying-glass"></i>
        <p>No members found matching your search.</p>
        <a asp-page="/Index" class="btn btn-outline-primary">Clear search</a>
    </div>
}
else
{
    <ul class="member-list member-list--index">
        @foreach (var m in Model.Members)
        {
            <li class="member-card" data-bs-toggle="modal" data-bs-target="#member-modal-@m.Id">
                <div class="member-card-photo">
                    @if (m.PhotoFileName != null)
                    {

                        <img src="@Model.PhotoUrl(m.PhotoFileName)" alt="photo" />

                    }
                    else
                    {
                        <i class="fa-solid fa-circle-user"></i>
                    }
                </div>
                <div class="member-card-info">
                    <strong class="member-name">@m.Name @m.Surname</strong>
                    @if (m.PhoneNumber != null)
                    {
                        <div class="card-text">
                            <i class="fa-solid fa-phone" style="color: var(--color-dark);"></i>
                            <span>@m.PhoneNumber</span>
                        </div>
                    }
                    @if (m.Birthdate.HasValue)
                    {
                        <div class="card-text">
                            <i class="fa-solid fa-cake" style="color: var(--color-dark);"></i>
                            <span>@m.Birthdate.Value.ToString("MMMM d")</span> 
                            @if (Model.IsUpcoming(m.Birthdate))
                            {
                                <span class="badge-upcoming">Upcoming</span>
                            }
                        
                        </div>
                        
                    }
                    @if (m.Anniversary.HasValue)
                    {
                        <div class="card-text">
                            <i class="fa-solid fa-gem" style="color: var(--color-dark);"></i>
                             @m.Anniversary.Value.ToString("MMMM d")
                            @if (Model.IsUpcoming(m.Anniversary))
                            {
                                <span class="badge-upcoming">Upcoming</span>
                            }
                        </div>
                    }
                   
                    @if (m.Family?.FamilyName != null)
                    {
                        <div class="badge-family" title="@m.Family.FamilyName">@(m.Family?.FamilyName ?? "")</div>
                    }
                    else
                    {
                        <div></div>
                    }

                </div>
              
            </li>
            <div class="modal fade" id="member-modal-@m.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@m.Name @m.Surname</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="member-modal-photo">
                                @if (m.PhotoFileName != null)
                                {
                                    <img src="@Model.PhotoUrl(m.PhotoFileName)" alt="photo" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-circle-user"></i>
                                }
                            </div>
                            <p><strong>Family:</strong> @(m.Family?.FamilyName ?? "—")</p>
                            <p><strong>Phone:</strong> @(m.PhoneNumber ?? "—")</p>
                            <p><strong>Birthday:</strong> @(m.Birthdate?.ToString("MMMM d") ?? "—")</p>
                            <p><strong>Anniversary:</strong> @(m.Anniversary?.ToString("MMMM d") ?? "—")</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </ul>
}