@page
@model HBCDirectory.Pages.Profile.IndexModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title">My Profile</h2>
    <a asp-page="/Index" class="btn btn-outline-secondary btn-sm">Back to Directory</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.HasPendingUpdate)
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <span>⏳</span>
        <span>You have changes pending admin approval. They will appear in the directory once reviewed.</span>
    </div>
}

@if (Model.CurrentMember != null)
{
    <div class="admin-card">
        <div class="card-header">Edit My Details</div>
        <div class="card-body">

            <div class="text-center mb-4">
                <img src="@Model.PhotoUrl(Model.CurrentMember.PhotoFileName)"
                     alt="Profile photo"
                     style="width:120px;height:120px;object-fit:cover;border-radius:50%;border:3px solid var(--color-primary)" />
            </div>

            <form method="post" enctype="multipart/form-data" class="admin-form-grid">

                <div class="form-field">
                    <label class="form-label">Name</label>
                    <input name="name" class="form-control" value="@Model.CurrentMember.Name" required />
                </div>
                <div class="form-field">
                    <label class="form-label">Surname</label>
                    <input name="surname" class="form-control" value="@Model.CurrentMember.Surname" required />
                </div>

                <div class="form-field">
                    <label class="form-label">Phone</label>
                    <input name="phoneNumber" class="form-control" value="@Model.CurrentMember.PhoneNumber" />
                </div>

                <div class="form-field">
                    <label class="form-label">Church Office</label>
                    @* Members cannot change their own church office — admin-only *@
                    <input class="form-control" value="@(Model.CurrentMember.ChurchOffice ?? "—")" readonly disabled />
                </div>

                <div class="form-field form-field--full">
                    <label class="form-label">Update Photo (leave empty to keep current)</label>
                    <input type="file" name="photo" class="form-control" accept="image/jpeg,image/png" />
                </div>

                <div class="form-field form-field--full">
                    <label class="form-label">Privacy Settings</label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="showPhone"
                                   id="showPhone" value="true" @(Model.CurrentMember.ShowPhone ? "checked" : "") />
                            <label class="form-check-label" for="showPhone">Show phone in directory</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="showBirthdate"
                                   id="showBirthdate" value="true" @(Model.CurrentMember.ShowBirthdate ? "checked" : "") />
                            <label class="form-check-label" for="showBirthdate">Show birthdate</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="showAnniversary"
                                   id="showAnniversary" value="true" @(Model.CurrentMember.ShowAnniversary ? "checked" : "") />
                            <label class="form-check-label" for="showAnniversary">Show anniversary</label>
                        </div>
                    </div>
                </div>

                <div class="form-field form-field--full">
                    <button type="submit" class="btn btn-primary">Submit for Review</button>
                    <p class="text-muted small mt-1">Changes go to the admin for approval before appearing in the directory.</p>
                </div>

            </form>
        </div>
    </div>
}
