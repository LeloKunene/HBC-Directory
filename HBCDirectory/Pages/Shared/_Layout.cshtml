<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]Heritage Directory</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/directory.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HBCDirectory.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&family=Open+Sans:wght@300;400;600;700&display=swap"
    rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#202222" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    <meta name="apple-mobile-web-app-title" content="HBC Directory" />
</head>

<body>
    <div class="app-toast-stack" id="app-toast-stack" aria-live="polite" aria-atomic="true"></div>

    @if (ViewData["HideNav"] as bool? != true)
    {
        <header>

            <nav class="nav navbar navbar-expand-sm sticky-top">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-page="/Index">
                        <img src="https://www.heritagebaptistlibrary.co.za/file.png" alt="Heritage Logo" class="nav-logo"
                             loading="lazy" />
                        <span>Heritage Directory</span>
                    </a>
                    <button class="hamburger navbar-toggler" type="button" data-bs-toggle="collapse"
                            data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="hamburger-bar"></span>
                        <span class="hamburger-bar"></span>
                        <span class="hamburger-bar"></span>
                    </button>
                    <div class="collapse navbar-collapse nav-links" id="navbarNav">
                        <ul class="navbar-nav flex-grow-1">
                            <li>
                                <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                            </li>
                            

                            @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Leadership")))
                            {
                                <li>
                                    <a asp-page="/Admin" class="nav-link">Admin</a>
                                </li>
                            }
                            @if (User.IsInRole("Leadership"))
                            {
                                <li>
                                    <a asp-page="/MemberManagement/Index" class="nav-link">Member Management</a>
                                </li>
                            }
                            @if (User.IsInRole("Member"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Profile/Index">My Profile</a>
                                </li>
                            }

                            <li>
                                <a asp-page="/Login" class="btn btn-logout">Logout</a>
                            </li>
                        </ul>
                    </div>
                </nav>
            </header>
        }
        @if (ViewData["HideChrome"] as bool? == true)
        {
            @RenderBody()
        }

        <div class="container">
            <main role="main" class="pb-3 pt-4">
                @RenderBody()
            </main>
        </div>

    
        @if (ViewData["HideFooter"] as bool? != true)
        {
            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 - Heritage Baptist Church Directory
                </div>
            </footer>
        }

   
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @{
            /* Every page's "flash" success/error message flows through here.
                set TempData["Success"]/TempData["Error"] in any handler before
                a RedirectToPage() and it shows as a toast on the next page,
                with no per-page markup needed. Read once, here, so it's
                consumed exactly once per request regardless of which page set it.*/
            var toastSuccess = TempData["Success"] as string;
            var toastError   = TempData["Error"]   as string;
        }
        @if (!string.IsNullOrEmpty(toastSuccess))
        {
            <script>document.addEventListener('DOMContentLoaded', () => window.showToast(@Json.Serialize(toastSuccess), 'success'));</script>
        }
        @if (!string.IsNullOrEmpty(toastError))
        {
            <script>document.addEventListener('DOMContentLoaded', () => window.showToast(@Json.Serialize(toastError), 'error'));</script>
        }
        <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
            navigator.serviceWorker.register('/service-worker.js')
                .then(reg => console.log('SW registered'))
                .catch(err => console.log('SW error:', err));
            });
        }
        </script>

        @await RenderSectionAsync("Scripts", required: false)
    </body>

</html>