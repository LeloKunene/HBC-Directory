<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HBCDirectory</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HBCDirectory.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&family=Open+Sans:wght@300;400;600;700&display=swap"
    rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>

<body>
    @if (ViewData["HideNav"] as bool? != true)
    {
        <header>

            <nav class="nav navbar navbar-expand-sm sticky-top">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-page="/Index">
                        <img src="https://www.heritagebaptistlibrary.co.za/file.png" alt="Heritage Logo" class="nav-logo"
                             loading="lazy" />
                        <span>Heritage Directory</span>
                    </a>
                    <button class="hamburger navbar-toggler" type="button" data-bs-toggle="collapse"
                            data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="hamburger-bar"></span>
                        <span class="hamburger-bar"></span>
                        <span class="hamburger-bar"></span>
                    </button>
                    <div class="collapse navbar-collapse nav-links" id="navbarNav">
                        <ul class="navbar-nav flex-grow-1">
                            <li>
                                <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                            </li>
                            <li>
                                <a class="nav-link" asp-area="" asp-page="/Privacy">Privacy</a>
                            </li>

                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <li>
                                    <a asp-page="/Admin" class="nav-link">Admin</a>
                                </li>
                            }
                            <li>
                                <a asp-page="/Login" class="btn btn-logout">Logout</a>
                            </li>
                        </ul>
                    </div>
                </nav>
            </header>
        }
        @if (ViewData["HideChrome"] as bool? == true)
        {
            @RenderBody()
        }

        <div class="container">
            <main role="main" class="pb-3">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>

    
        @if (ViewData["HideFooter"] as bool? != true)
        {
            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 - HBCDirectory - <a asp-area="" asp-page="/Privacy">Privacy</a>
                </div>
            </footer>
        }

   
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)
    </body>

</html>