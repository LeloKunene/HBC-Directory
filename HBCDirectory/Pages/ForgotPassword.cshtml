@page
@model HBCDirectory.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["HideNav"] = true;
    ViewData["HideFooter"] = true;
}

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <div class="login-title">Heritage Directory</div>
            <div class="login-divider">
                <span class="divider-ornament">✦</span>
            </div>
            <p class="login-subtitle">Forgot your password?</p>
        </div>

        @if (Model.Sent)
        {
            <div class="alert alert-success">
                If that email is registered, a reset link has been sent. Check your inbox.
            </div>
            <div class="text-center mt-3">
                <a asp-page="/Login" class="btn btn-outline-secondary btn-sm">Back to Login</a>
            </div>
        }
        else
        {
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input name="email" type="email" class="form-control"
                           autocomplete="email" placeholder="your@email.com" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
            </form>
            <div class="text-center mt-3">
                <a asp-page="/Login" class="small text-muted">Back to Login</a>
            </div>
        }
    </div>
</div>
