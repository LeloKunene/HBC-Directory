@page
@model HBCDirectory.Pages.AdminModel
@using Microsoft.AspNetCore.Authorization
@{
    ViewData["Title"] = "Admin";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-2">
    <h2 class="page-title">Admin Dashboard</h2>
    <div class="d-flex flex-wrap gap-2">
        <a asp-page="/Directory/Download" class="btn btn-outline-secondary btn-sm">
            Download PDF Directory
        </a>
        <a asp-page="/Index" class="btn btn-outline-secondary btn-sm">View Directory</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="admin-stat-card">
            <div class="admin-stat-value">@Model.TotalMembers</div>
            <div class="admin-stat-label">TOTAL MEMBERS</div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="admin-stat-card">
            <div class="admin-stat-value">@Model.TotalFamilies</div>
            <div class="admin-stat-label">TOTAL FAMILIES</div>
        </div>
    </div>
</div>
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="admin-card">
            <div class="card-header">Upcoming Birthdays <span class="text-muted small">(next 30 days)</span></div>
            <div class="card-body">
                @if (Model.UpcomingBirthdays.Any())
                {
                    <ul class="upcoming-list">
                        @foreach (var m in Model.UpcomingBirthdays)
                        {
                            <li class="upcoming-list-item">
                                <span>@m.Name @m.Surname</span>
                                <span class="upcoming-date">@m.Birthdate!.Value.ToString("MMMM d")</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">None in the next 30 days</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="admin-card">
            <div class="card-header">Upcoming Anniversaries <span class="text-muted small">(next 30 days)</span></div>
            <div class="card-body">
                @if (Model.UpcomingAnniversaries.Any())
                {
                    <ul class="upcoming-list">
                        @foreach (var m in Model.UpcomingAnniversaries)
                        {
                            <li class="upcoming-list-item">
                                <span>@m.Name @m.Surname</span>
                                <span class="upcoming-date">@m.Anniversary!.Value.ToString("MMMM d")</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">None in the next 30 days</p>
                }
            </div>
        </div>
    </div>
</div>
<div class="admin-card">
    <div class="card-header">Families</div>
    <div class="card-body">

        <form method="post" asp-page-handler="AddFamily" class="admin-add-form">
            <input name="FamilyName" placeholder="Family name" class="form-control" style="max-width: 240px" required />
            <button type="submit" class="btn btn-primary btn-sm">Add Family</button>
        </form>

        @if (Model.EditingFamily != null)
        {
            <div class="mt-3 p-3 border rounded">
                <strong>Renaming: @Model.EditingFamily.FamilyName</strong>
                <form method="post" asp-page-handler="EditFamily" class="d-flex gap-2 mt-2">
                    <input type="hidden" name="familyId" value="@Model.EditingFamily.Id" />
                    <input name="familyName" value="@Model.EditingFamily.FamilyName" class="form-control form-control-sm"
                           style="max-width: 240px" />
                    <button type="submit" class="btn btn-primary btn-sm">Rename</button>
                    <a asp-page="/Admin" class="btn btn-outline-secondary btn-sm">Cancel</a>
                </form>
                <form method="post" enctype="multipart/form-data" asp-page-handler="EditFamily"
                      class="d-flex align-items-end gap-3 mt-3">
                    <input type="hidden" name="familyId" value="@Model.EditingFamily.Id" />
                    <input type="hidden" name="familyName" value="@Model.EditingFamily.FamilyName" />

                    @if (Model.EditingFamily.PhotoFileName != null)
                    {
                        <img src="@Model.PhotoUrl(Model.EditingFamily.PhotoFileName)" alt="family photo" class="table-avatar" />
                    }
                    else
                    {
                        <i class="fa-solid fa-people-roof table-avatar-icon"></i>
                    }

                    <div class="form-field">
                        <label class="form-label">New Photo (leave empty to keep current)</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="file" name="photo" accept="image/jpeg,image/png"
                                   class="form-control form-control-sm" style="max-width: 220px" />
                            <button type="submit" class="btn btn-outline-primary btn-sm">Upload Photo</button>
                        </div>
                    </div>
                </form>
            </div>
        }

        <table class="table table-hover align-middle mb-0 mt-3">
            <thead>
                <tr>
                    <th>Family Name</th>
                    <th>Members</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Families)
                {
                    <tr>
                        <td class="member-name">@f.FamilyName</td>
                        <td>@Model.Members.Count(m => m.FamilyId == f.Id)</td>
                        <td class="text-end">
                            <div class="d-flex flex-wrap gap-2 justify-content-end">
                                <a asp-page="/Admin" asp-route-editFamilyId="@f.Id"
                                   class="btn btn-outline-primary btn-sm">Edit</a>

                                <form method="post" asp-page-handler="DeleteFamily" class="d-inline">
                                    <input type="hidden" name="familyId" value="@f.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm"
                                            onclick="return confirm('Delete @f.FamilyName? All members in this family will also be deleted.')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@if (Model.EditingMember != null)
{
    <div class="admin-card  admin-card--editing">
        <div class="card-header">
            Editing: @Model.EditingMember.Name @Model.EditingMember.Surname
        </div>
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" asp-page-handler="EditMember" class="admin-form-grid">
                <input type="hidden" name="memberId" value="@Model.EditingMember.Id" />

                <div class="form-field">
                    <label class="form-label">Name</label>
                    <input name="Name" class="form-control" value="@Model.EditingMember.Name" required />
                </div>
                <div class="form-field">
                    <label class="form-label">Surname</label>
                    <input name="Surname" class="form-control" value="@Model.EditingMember.Surname" required />
                </div>

                <div class="form-field">
                    <label class="form-label">Birthdate</label>
                    <input name="Birthdate" type="date" class="form-control"
                           value="@Model.EditingMember.Birthdate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-field">
                    <label class="form-label">Anniversary</label>
                    <input name="Anniversary" type="date" class="form-control"
                           value="@Model.EditingMember.Anniversary?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-field ">
                    <label class="form-label">Email Address <span class="text-danger">*</span></label>
                    <input name="Email" type="email" placeholder="member@email.com" class="form-control" 
                           value="@Model.EditingMember.Email" required />
                    <div class="form-text">Login username. A welcome email will be sent.</div>
                </div>
                <div class="form-field">
                    <label class="form-label">
                        Role <span class="text-danger">*</span>
                    </label>
                    <select name="role" class="form-select">
                        <option value="">-- none --</option>
                        @foreach (var role in AdminModel.AllowedRoles)
                        {
                            <option value="@role" selected="@(Model.EditingMember.Role == role)">@role</option>
                        }
                    </select>
                </div>


                <div class="form-field">
                    <label class="form-label">Phone</label>
                    <input name="PhoneNumber" class="form-control" value="@Model.EditingMember.PhoneNumber" />
                </div>
                <div class="form-field">
                    <label class="form-label">Family</label>
                    <select name="FamilyId" class="form-select" value="@Model.EditingMember.Family">
                        <option value="">-- none --</option>
                        @foreach (var f in Model.Families)
                        {
                            <option value="@f.Id" selected="@(Model.EditingMember.FamilyId == f.Id)">@f.FamilyName</option>
                        }
                    </select>
                </div>
                
                <div class="form-field form-field--full">
                    <label class="form-label">New Photo (leave empty to keep current)</label>
                    <input type="file" name="Photo" class="form-control" accept="image/jpeg,image/png" />
                </div>

                <div class="form-field form-field--full d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-page="/Admin" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}

<div class="admin-card">
    <div class="card-header">Add Member</div>
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" asp-page-handler="AddMember" class="admin-form-grid">

            <div class="form-field">
                <label class="form-label">Name <span class="text-danger">*</span></label>
                <input name="Name" placeholder="Name" class="form-control" required />
            </div>
            <div class="form-field">
                <label class="form-label">Surname <span class="text-danger">*</span></label>
                <input name="Surname" placeholder="Surname" class="form-control" required />
            </div>

            <div class="form-field ">
                <label class="form-label">Email Address <span class="text-danger">*</span></label>
                <input name="Email" type="email" placeholder="member@email.com" class="form-control" required />
                <div class="form-text">Login username. A welcome email will be sent.</div>
            </div>

            <div class="form-field">
                <label class="form-label">
                    Role <span class="text-danger">*</span>
                </label>
                <select name="role" class="form-select">
                    <option value="">-- none --</option>
                    @foreach (var role in AdminModel.AllowedRoles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>  
            </div>

            <div class="form-field">
                <label class="form-label">Birthdate <span class="text-danger">*</span></label>
                <input name="Birthdate" type="date" class="form-control" required />
            </div>
            <div class="form-field">
                <label class="form-label">Anniversary</label>
                <input name="Anniversary" type="date" class="form-control" />
            </div>

            <div class="form-field">
                <label class="form-label">Phone <span class="text-danger">*</span></label>
                <input name="PhoneNumber" placeholder="Phone" class="form-control" required />
            </div>
            <div class="form-field">
                <label class="form-label">Family</label>
                <select name="FamilyId" class="form-select">
                    <option value="">-- none --</option>
                    @foreach (var f in Model.Families)
                    {
                        <option value="@f.Id">@f.FamilyName</option>
                    }
                </select>
            </div>

            <div class="form-field form-field--full">
                <label class="form-label">Photo (JPG or PNG, max 2MB)</label>
                <input type="file" name="Photo" class="form-control" accept="image/jpeg,image/png" />
            </div>

            <div class="form-field form-field--full">
                <button type="submit" class="btn btn-primary">Add Member</button>
                <p class="small text-muted mt-2"><span class="text-danger">*</span> Required fields</p>
            </div>

        </form>
    </div>
</div>

<div class="admin-card">
    <div class="card-header">Members</div>
    <div class="card-body">
        <div class="table-scroll">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Photo</th>
                        <th>Name</th>
                        <th>Family</th>
                        <th>Birthdate</th>
                        <th>Anniversary</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Members)
                    {
                        <tr>
                            <td>
                                @if (m.PhotoFileName != null)
                                {
                                    <img src="@Model.PhotoUrl(m.PhotoFileName)" alt="photo" class="table-avatar" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-circle-user table-avatar-icon"></i>
                                }
                            </td>
                            <td class="member-name">@m.Name @m.Surname</td>
                            <td>@(m.Family?.FamilyName ?? "—")</td>
                            <td>@(m.Birthdate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td>@(m.Anniversary?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td>@(m.Role ?? "—")</td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-end">
                                    <a asp-page="/Admin" asp-route-editMemberId="@m.Id"
                                       class="btn btn-outline-primary btn-sm">Edit</a>

                                    <form method="post" asp-page-handler="DeleteMember" class="d-inline">
                                        <input type="hidden" name="memberId" value="@m.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('Delete @m.Name @m.Surname?')">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
    </div>
</div>