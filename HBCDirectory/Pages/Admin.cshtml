@page
@using System.Text.Json
@model HBCDirectory.Pages.AdminModel
@{
    ViewData["Title"] = "Admin | ";
    Layout = "_Layout";
}

<!-- Success/error messages now render as toasts globally — see Pages/Shared/_Layout.cshtml -->

<!--  Stats + quick actions  -->
<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div class="stats-row mb-0">
        @foreach (var stat in Model.Stats)
        {
            <div class="stat-pill">
                <span class="stat-pill-value">@stat.Value</span>
                <span class="stat-pill-label">@stat.Label</span>
            </div>
        }
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-address-book me-1"></i>View Directory
        </a>
        <a href="/Directory/Download" class="btn btn-primary btn-sm" target="_blank">
            <i class="fa-solid fa-file-pdf me-1"></i>Download PDF
        </a>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     MEMBERS SECTION
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Members</h4>
        <button class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#addMemberForm">
            + Add Member
        </button>
    </div>

    <!-- Add Member Form -->
    <div class="collapse" id="addMemberForm">
        <div class="form-card mb-4">
            <h6 class="form-card-title">Add New Member</h6>
            <form method="post" asp-page-handler="AddMember" enctype="multipart/form-data"
                  onsubmit="return combinePhone('add-phone-code','add-phone-local','add-phone-hidden')">

                <div class="form-grid">
                    <div class="form-field">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input name="name" class="form-control" required />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Surname <span class="text-danger">*</span></label>
                        <input name="surname" class="form-control" required />
                    </div>
                    <div class="form-field form-field--full">
                        <label class="form-label">Member Type <span class="text-danger">*</span></label>
                        <select name="memberType" class="form-select" id="add-memberType" onchange="updateAddForm()">
                            <option value="Adult">Adult</option>
                            <option value="Child">Child</option>
                        </select>
                    </div>
                    <div class="form-field" id="add-statusField">
                        <label class="form-label">Member Status</label>
                        <select name="memberStatus" class="form-select" id="add-memberStatus" onchange="updateAddForm()">
                            <option value="Member">Member</option>
                            <option value="Attendant">Attendant</option>
                        </select>
                    </div>
                    <div class="form-field" id="add-officeField">
                        <label class="form-label">Church Office</label>
                        <select name="churchOffice" class="form-select">
                            <option value="">None</option>
                            <option value="Elder">Elder</option>
                            <option value="Deacon">Deacon</option>
                        </select>
                    </div>
                    <div class="form-field form-field--full" id="add-emailField">
                        <label class="form-label">Email Address <span class="text-danger" id="add-email-required-mark">*</span></label>
                        <input name="email" type="email" class="form-control" id="add-email"
                               placeholder="Used as login username — required for Members, optional for Attendants" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Birthdate</label>
                        <input name="birthdate" type="date" class="form-control" />
                    </div>
                    <div class="form-field" id="add-anniversaryField">
                        <label class="form-label">Anniversary</label>
                        <input name="anniversary" type="date" class="form-control" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Phone</label>
                        <div class="phone-input-group">
                            <select class="form-select phone-country-code" id="add-phone-code" data-default="+27"></select>
                            <input type="tel" class="form-control" id="add-phone-local" placeholder="82 123 4567" />
                        </div>
                        <input type="hidden" name="phoneNumber" id="add-phone-hidden" />
                    </div>
                    <div class="form-field" id="add-dateJoinedField">
                        <label class="form-label">Date Became Member</label>
                        <input name="dateJoined" type="date" class="form-control" />
                    </div>
                    <div class="form-field form-field--full" id="add-addressField">
                        <label class="form-label">Address <span class="text-muted small">(individual members only)</span></label>
                        <input name="address" class="form-control" placeholder="Street, suburb" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Family</label>
                        <select name="familyId" class="form-select">
                            <option value="">— Individual member —</option>
                            @foreach (var f in Model.Families)
                            {
                                <option value="@f.Id">@Model.FamilyDisambiguated(f)</option>
                            }
                        </select>
                    </div>
                    <div class="form-field form-field--full">
                        <label class="form-label">Photo</label>
                        <input name="photo" type="file" class="form-control" accept="image/*" />
                    </div>
                    <div class="form-field form-field--full">
                        <p class="small text-muted">
                            <i class="fa-solid fa-circle-info me-1"></i>
                            Care Group assignment is managed via the Groups &amp; Ministries section below.
                        </p>
                    </div>
                </div>

                <p class="small text-muted mt-2"><span class="text-danger">*</span> Required</p>
                <button type="submit" class="btn btn-primary">Add Member</button>
            </form>
        </div>
    </div>

    <!-- Members Table -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <input type="text" id="members-search" class="form-control form-control-sm" style="max-width:300px;"
               placeholder="Search members by name, email, or family…" onkeyup="filterTableRows('members-search', 'members-table')" />
    </div>
    <div class="table-responsive">
        <table class="table table-hover" id="members-table">
            <thead>
                <tr>
                    <th>Photo</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Status / Office</th>
                    <th>Family</th>
                    <th>Phone</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Members)
                {
                    <tr data-search="@($"{m.Name} {m.Surname} {m.Email} {m.Family?.FamilyName}".ToLowerInvariant())">
                        <td>
                            @if (!string.IsNullOrEmpty(m.PhotoFileName))
                            {
                                <img src="@Model.PhotoUrl(m.PhotoFileName)" class="member-thumb" alt="@m.DisplayName" />
                            }
                            else
                            {
                                <div class="member-thumb-placeholder">@m.Name[0]@m.Surname[0]</div>
                            }
                        </td>
                        <td><strong>@m.Surname, @m.Name</strong></td>
                        <td>
                            <span class="badge-type @(m.IsChild ? "badge-child" : "badge-adult")">
                                @m.MemberType
                            </span>
                        </td>

                        <td>
                            @{ var displayStatus = Model.AdminDisplayStatus(m); }
                            @if (!string.IsNullOrEmpty(displayStatus))
                            {
                                <span class="badge-status">@displayStatus</span>
                            }
                            @if (!string.IsNullOrEmpty(m.ChurchOffice))
                            {
                                <span class="badge-office badge-office--@m.ChurchOffice.ToLower()">@m.ChurchOffice</span>
                            }
                        </td>
                        <td>@(m.Family?.FamilyName ?? "—")</td>
                        <td>@(m.PhoneNumber ?? "—")</td>
                        <td class="text-muted small">@(m.DateJoined?.ToString("MMM yyyy") ?? "—")</td>
                        <td>
                            <button class="btn btn-xs btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editMemberModal"
                                    data-id="@m.Id"
                                    data-name="@m.Name"
                                    data-surname="@m.Surname"
                                    data-email="@m.Email"
                                    data-membertype="@m.MemberType"
                                    data-memberstatus="@Model.AdminDisplayStatus(m)"
                                    data-churchoffice="@m.ChurchOffice"
                                    data-birthdate="@(m.Birthdate?.ToString("yyyy-MM-dd"))"
                                    data-anniversary="@(m.Anniversary?.ToString("yyyy-MM-dd"))"
                                    data-phone="@m.PhoneNumber"
                                    data-familyid="@m.FamilyId"
                                    data-showphone="@m.ShowPhone.ToString().ToLower()"
                                    data-showaddress="@m.ShowAddress.ToString().ToLower()"
                                    data-showbirthdate="@m.ShowBirthdate.ToString().ToLower()"
                                    data-showanniversary="@m.ShowAnniversary.ToString().ToLower()"
                                    data-datejoined="@(m.DateJoined?.ToString("yyyy-MM-dd"))"
                                    data-address="@m.Address">
                                Edit
                            </button>
                            <form method="post" asp-page-handler="DeleteMember" class="d-inline"
                                  onsubmit="return confirm('Delete @m.DisplayName?')">
                                <input type="hidden" name="id" value="@m.Id" />
                                <button type="submit" class="btn btn-xs btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     FAMILIES SECTION
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Families</h4>
        <button class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#addFamilyForm">
            + Add Family
        </button>
    </div>

    <div class="collapse" id="addFamilyForm">
        <div class="form-card mb-4">
            <h6 class="form-card-title">Add New Family</h6>
            <form method="post" asp-page-handler="AddFamily" enctype="multipart/form-data"
                  onsubmit="return combinePhone('add-fphone-code','add-fphone-local','add-fphone-hidden')">
                <div class="form-grid">
                    <div class="form-field form-field--full">
                        <label class="form-label">Family Name <span class="text-danger">*</span></label>
                        <input name="familyName" class="form-control" required />
                    </div>
                    <div class="form-field form-field--full">
                        <label class="form-label">Address</label>
                        <input name="address" class="form-control" placeholder="Street address, suburb" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Family Phone</label>
                        <div class="phone-input-group">
                            <select class="form-select phone-country-code" id="add-fphone-code" data-default="+27"></select>
                            <input type="tel" class="form-control" id="add-fphone-local" placeholder="82 123 4567" />
                        </div>
                        <input type="hidden" name="familyPhone" id="add-fphone-hidden" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">Group Photo</label>
                        <input name="photo" type="file" class="form-control" accept="image/*" />
                    </div>
                    <div class="form-field form-field--full">
                        <label class="form-label">Additional Notes</label>
                        <textarea name="additionalNotes" class="form-control" rows="2"
                                  placeholder="e.g. Joined 2021, ministry notes..."></textarea>
                    </div>
                </div>
                <p class="small text-muted mt-2"><span class="text-danger">*</span> Required</p>
                <button type="submit" class="btn btn-primary">Create Family</button>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <input type="text" id="families-search" class="form-control form-control-sm" style="max-width:300px;"
               placeholder="Search families by name or member…" onkeyup="filterTableRows('families-search', 'families-table')" />
    </div>
    <div class="table-responsive">
        <table class="table table-hover" id="families-table">
            <thead>
                <tr>
                    <th>Photo</th>
                    <th>Family</th>
                    <th>Address</th>
                    <th>Phone</th>
                    <th>Members</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Families)
                {
                    <tr data-search="@($"{f.FamilyName} {string.Join(" ", f.Members.Select(m => m.Name + " " + m.Surname))}".ToLowerInvariant())">
                        <td>
                            @if (!string.IsNullOrEmpty(f.PhotoFileName))
                            {
                                <img src="@Model.PhotoUrl(f.PhotoFileName)" class="member-thumb" alt="@f.FamilyName" />
                            }
                            else
                            {
                                <div class="member-thumb-placeholder" style="background:var(--dark);color:var(--mustard);">
                                    @f.FamilyName[0]
                                </div>
                            }
                        </td>
                        <td>
                            <strong>@f.FamilyName</strong>
                            @{ var sameNameCount = Model.Families.Count(x => x.FamilyName == f.FamilyName); }
                            @if (sameNameCount > 1)
                            {
                                if (f.HeadOfFamily != null)
                                {
                                    <span class="text-muted small">(@f.HeadOfFamily.Name)</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark small"
                                          title="Multiple families share this surname — set a head from Edit Family so they can be told apart.">
                                        <i class="fa-solid fa-triangle-exclamation"></i> No head set
                                    </span>
                                }
                            }
                        </td>
                        <td class="text-muted small">@(f.Address ?? "—")</td>
                        <td class="text-muted small">@(f.FamilyPhone ?? "—")</td>
                        <td>
                            <span class="text-muted small">
                                @(string.Join(", ", Model.VisibleAdultsFor(f).Select(m => m.Name)))
                                @if (f.Children.Any())
                                {
                                    <em> · @string.Join(", ", f.Children.Select(c => c.Name))</em>
                                }
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-xs btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editFamilyModal"
                                    data-id="@f.Id"
                                    data-familyname="@f.FamilyName"
                                    data-address="@f.Address"
                                    data-familyphone="@f.FamilyPhone"
                                    data-notes="@f.AdditionalNotes"
                                    data-headoffamilyid="@f.HeadOfFamilyId"
                                    data-members='@System.Text.Json.JsonSerializer.Serialize(Model.VisibleMembersFor(f).Select(m => new {
                                        id = m.Id,
                                        name = m.Name,
                                        surname = m.Surname,
                                        type = m.MemberType,
                                        status = Model.AdminDisplayStatus(m),
                                        office = m.ChurchOffice,
                                        birthdate = m.Birthdate.HasValue
                                            ? m.Birthdate.Value.ToString("d MMM yyyy")
                                            : (string?)null
                                    }))'>
                                Edit
                            </button>
                            <form method="post" asp-page-handler="DeleteFamily" class="d-inline"
                                  onsubmit="return confirm('Delete @f.FamilyName family? Adults will become individual members.')">
                                <input type="hidden" name="id" value="@f.Id" />
                                <button type="submit" class="btn btn-xs btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     STAFF SECTION
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
<div class="admin-section-header mb-3">
    <h4 class="mb-0">Staff</h4>
</div>

    <div class="row g-4">
        <!-- Staff Roles -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Staff Roles</h6>
                <form method="post" asp-page-handler="AddStaffRole" class="mb-3">
                    <div class="input-group">
                        <input name="roleName" class="form-control" placeholder="New role name..." required />
                        <button type="submit" class="btn btn-primary">Add</button>
                    </div>
                </form>
                <ul class="list-group list-group-flush">
                    @foreach (var role in Model.StaffRoles)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>@role.RoleName</span>
                            <form method="post" asp-page-handler="DeleteStaffRole"
                                  onsubmit="return confirm('Delete role @role.RoleName?')">
                                <input type="hidden" name="id" value="@role.Id" />
                                <button type="submit" class="btn btn-xs btn-outline-danger">Remove</button>
                            </form>
                        </li>
                    }
                    @if (!Model.StaffRoles.Any())
                    {
                        <li class="list-group-item px-0 text-muted small">No staff roles yet.</li>
                    }
                </ul>
            </div>
        </div>

        <!-- Assign Staff -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Assign Staff Role</h6>
                <form method="post" asp-page-handler="AssignStaff">
                    <div class="mb-2">
                        <label class="form-label">Member</label>
                        <select name="memberId" class="form-select">
                            @foreach (var m in Model.Members.Where(m => m.MemberType == "Adult"))
                            {
                                <option value="@m.Id">@m.Surname, @m.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Staff Role</label>
                        <select name="staffRoleId" class="form-select">
                            @foreach (var r in Model.StaffRoles)
                            {
                                <option value="@r.Id">@r.RoleName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Display Order</label>
                        <input name="displayOrder" type="number" class="form-control" value="1" min="1" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Bio (shown in PDF)</label>
                        <textarea name="bio" class="form-control" rows="2" placeholder="Optional short bio..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Save Assignment</button>
                </form>
            </div>
        </div>

        <!-- Current Staff -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Current Staff</h6>
                @if (!Model.StaffAssignments.Any())
                {
                    <p class="text-muted small">No staff assigned yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var sa in Model.StaffAssignments)
                        {
                            <li class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong class="d-block">@sa.Member.DisplayName</strong>
                                        <span class="text-muted small">@sa.StaffRole.RoleName</span>
                                    </div>
                                    <form method="post" asp-page-handler="RemoveStaff">
                                        <input type="hidden" name="id" value="@sa.Id" />
                                        <button type="submit" class="btn btn-xs btn-outline-danger">Remove</button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     GROUPS / MINISTRY MEMBERSHIPS
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
<div class="admin-section-header mb-3">
    <h4 class="mb-0">Groups & Ministries</h4>
</div>
    <div class="row g-4">

        <!-- Create group -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Create Group</h6>
                <form method="post" asp-page-handler="AddGroup">
                    <div class="mb-2">
                        <label class="form-label">Group Name</label>
                        <input name="groupName" class="form-control" required
                               placeholder="e.g. Welcome Team, Tea & Coffee..." />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Description (optional)</label>
                        <input name="description" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Create Group</button>
                </form>
                <ul class="list-group list-group-flush mt-3">
                    @foreach (var g in Model.Groups)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>@g.Name</span>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-secondary" title="Rename"
                                        data-bs-toggle="modal" data-bs-target="#editGroupModal"
                                        data-groupid="@g.Id" data-groupname="@g.Name">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <form method="post" asp-page-handler="DeleteGroup"
                                      onsubmit="return confirm('Delete group @g.Name?')">
                                    <input type="hidden" name="id" value="@g.Id" />
                                    <button type="submit" class="btn btn-xs btn-outline-danger">Remove</button>
                                </form>
                            </div>
                        </li>
                    }
                    @if (!Model.Groups.Any())
                    {
                        <li class="list-group-item px-0 text-muted small">No groups yet.</li>
                    }
                </ul>
            </div>
        </div>

        <!-- Add member to group -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Add Member to Group</h6>
                <form method="post" asp-page-handler="AddMemberToGroup">
                    <div class="mb-2">
                        <label class="form-label">Member</label>
                        <select name="memberId" class="form-select">
                            @foreach (var m in Model.Members.Where(m => m.MemberType == "Adult"))
                            {
                                <option value="@m.Id">@m.Surname, @m.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Group</label>
                        <select name="groupId" class="form-select">
                            @foreach (var g in Model.Groups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Add to Group</button>
                </form>
            </div>
        </div>

        <!-- Current group memberships -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Group Memberships</h6>
                @if (!Model.MemberGroups.Any())
                {
                    <p class="text-muted small">No assignments yet.</p>
                }
                else
                {
                    @foreach (var g in Model.Groups)
                    {
                        var groupMembers = Model.MemberGroups.Where(mg => mg.GroupId == g.Id).ToList();
                        if (!groupMembers.Any()) continue;
                        <p class="small fw-bold text-uppercase" style="color:var(--dir-gold);letter-spacing:.06em;margin-bottom:4px;">@g.Name</p>
                        @foreach (var mg in groupMembers)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="small">@mg.Member.Surname, @mg.Member.Name</span>
                                <form method="post" asp-page-handler="RemoveMemberFromGroup">
                                    <input type="hidden" name="id" value="@mg.Id" />
                                    <button type="submit" class="btn btn-xs btn-outline-danger"
                                            style="font-size:10px;padding:1px 6px;">✕</button>
                                </form>
                            </div>
                        }
                        <hr style="border-color:#ede8df;margin:8px 0;" />
                    }
                }
            </div>
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     CARE GROUPS: pastoral care, standalone from Groups & Ministries above.
     Admin + Leadership both manage this (Admin does the data entry, per
     elder instruction), this is never shown on the public directory.
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
<div class="admin-section-header mb-3">
    <h4 class="mb-0">Care Groups</h4>
    <p class="text-muted small mb-0">Pastoral care assignments: who's shepherding whom. Separate from Groups &amp; Ministries above; shown on each member's public directory card.</p>
</div>
    <div class="row g-4">

        <!-- Create care group -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Create Care Group</h6>
                <form method="post" asp-page-handler="AddCareGroup">
                    <div class="mb-2">
                        <label class="form-label">Care Group Name</label>
                        <input name="careGroupName" class="form-control" required
                               placeholder="e.g. Braamfontein" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Create Care Group</button>
                </form>
                <ul class="list-group list-group-flush mt-3">
                    @foreach (var cg in Model.CareGroups)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>@cg.Name</span>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-xs btn-outline-secondary" title="Rename"
                                        data-bs-toggle="modal" data-bs-target="#editCareGroupModal"
                                        data-caregroupid="@cg.Id" data-caregroupname="@cg.Name">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <form method="post" asp-page-handler="DeleteCareGroup"
                                      onsubmit="return confirm('Delete care group @cg.Name? This does not delete any members, just the grouping.')">
                                    <input type="hidden" name="id" value="@cg.Id" />
                                    <button type="submit" class="btn btn-xs btn-outline-danger">Remove</button>
                                </form>
                            </div>
                        </li>
                    }
                    @if (!Model.CareGroups.Any())
                    {
                        <li class="list-group-item px-0 text-muted small">No care groups yet.</li>
                    }
                </ul>
            </div>
        </div>


        <!-- Assign leader -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Assign Overseer</h6>
                <form method="post" asp-page-handler="AddCareGroupLeader">
                    <div class="mb-2">
                        <label class="form-label">Member</label>
                        <select name="memberId" class="form-select">
                            @foreach (var m in Model.Members.Where(m => m.MemberType == "Adult"))
                            {
                                <option value="@m.Id">@m.Surname, @m.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Care Group</label>
                        <select name="careGroupId" class="form-select">
                            @foreach (var cg in Model.CareGroups)
                            {
                                <option value="@cg.Id">@cg.Name</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Assign as Overseer</button>
                </form>
            </div>
        </div>

        <!-- Assign member -->
        <div class="col-md-4">
            <div class="form-card h-100">
                <h6 class="form-card-title">Assign Member</h6>
                <p class="text-muted small">A member can only be under one care group at a time, assigning them to a new one moves them.</p>
                <form method="post" asp-page-handler="AddMemberToCareGroup">
                    <div class="mb-2">
                        <label class="form-label">Member</label>
                        <select name="memberId" class="form-select">
                            @foreach (var m in Model.Members.Where(m => m.MemberType == "Adult"))
                            {
                                <option value="@m.Id">@m.Surname, @m.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Care Group</label>
                        <select name="careGroupId" class="form-select">
                            @foreach (var cg in Model.CareGroups)
                            {
                                <option value="@cg.Id">@cg.Name</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Assign Member</button>
                </form>
            </div>
        </div>

        <!-- Overview -->
        <div class="col-12">
            <div class="form-card">
                <h6 class="form-card-title">Care Groups Overview</h6>
                @if (!Model.CareGroups.Any())
                {
                    <p class="text-muted small">No care groups yet.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var cg in Model.CareGroups)
                        {
                            <div class="col-md-4">
                                <p class="small fw-bold text-uppercase" style="color:var(--dir-gold);letter-spacing:.06em;margin-bottom:4px;">@cg.Name</p>

                                <p class="small text-muted mb-1">Overseer@(cg.Leaders.Count == 1 ? "" : "s"):</p>
                                @if (!cg.Leaders.Any())
                                {
                                    <p class="small text-muted fst-italic">None assigned</p>
                                }
                                @foreach (var l in cg.Leaders)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small">@l.Member.Surname, @l.Member.Name</span>
                                        <form method="post" asp-page-handler="RemoveCareGroupLeader">
                                            <input type="hidden" name="id" value="@l.Id" />
                                            <button type="submit" class="btn btn-xs btn-outline-danger"
                                                    style="font-size:10px;padding:1px 6px;">✕</button>
                                        </form>
                                    </div>
                                }

                                <p class="small text-muted mb-1 mt-2">Members:</p>
                                @if (!cg.Members.Any())
                                {
                                    <p class="small text-muted fst-italic">None assigned</p>
                                }
                                @foreach (var cgm in cg.Members)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small">@cgm.Member.Surname, @cgm.Member.Name</span>
                                        <form method="post" asp-page-handler="RemoveMemberFromCareGroup">
                                            <input type="hidden" name="id" value="@cgm.Id" />
                                            <button type="submit" class="btn btn-xs btn-outline-danger"
                                                    style="font-size:10px;padding:1px 6px;">✕</button>
                                        </form>
                                    </div>
                                }
                                <hr style="border-color:#ede8df;margin:8px 0;" />
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     PDF MANAGEMENT SECTION
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">
            <i class="fa-solid fa-file-pdf me-2" style="color:var(--dir-mustard);"></i>PDF Directory
        </h4>
        <form method="post" asp-page-handler="GeneratePdf">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-arrows-rotate me-1"></i>Update PDF
            </button>
        </form>
    </div>

    <!-- Status banner -->
    <div class="form-card mb-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                @if (Model.PdfConfig.LastGenerated.HasValue)
                {
                    <p class="mb-0" style="font-size:13px;">
                        <i class="fa-solid fa-check-circle me-1" style="color:#4a6741;"></i>
                        <strong>PDF ready</strong> — last updated
                        <strong>@Model.PdfConfig.LastGenerated.Value.ToLocalTime().ToString("d MMM yyyy, HH:mm")</strong>
                    </p>
                    <p class="mb-0 text-muted small mt-1">
                        @if (Model.PdfConfig.HasPassword)
                        {
                            <span><i class="fa-solid fa-lock me-1"></i>Password protected</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-lock-open me-1"></i>No password</span>
                        }
                    </p>
                }
                else
                {
                    <p class="mb-0 text-muted" style="font-size:13px;">
                        <i class="fa-solid fa-circle-info me-1"></i>
                        No PDF generated yet. Click <strong>Update PDF</strong> to create one.
                    </p>
                }
            </div>
            @if (Model.PdfConfig.LastGenerated.HasValue)
            {
                <a href="/Directory/Download" target="_blank" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-solid fa-download me-1"></i>Download current PDF
                </a>
            }
        </div>
    </div>

    <!-- Page configuration -->
    <div class="row g-3">
        <div class="col-md-7">
            <div class="form-card h-100">
                <h6 class="form-card-title">
                    <i class="fa-solid fa-list-ol me-1"></i>Pages — choose what to include and the order
                </h6>
                <form method="post" asp-page-handler="SavePdfSettings" id="pdfSettingsForm">
                    <div id="pdfPagesList">
                        @{
                            var pdfPages = Model.PdfConfig.GetPages().OrderBy(p => p.Order).ToList();
                        }
                        @foreach (var pg in pdfPages)
                        {
                            <div class="pdf-page-row" data-key="@pg.Key">
                                <div class="pdf-page-drag" title="Drag to reorder">
                                    <i class="fa-solid fa-grip-vertical"></i>
                                </div>
                                <div class="pdf-page-order">@pg.Order</div>
                                <div class="form-check mb-0">
                                    <input class="form-check-input pdf-page-check"
                                           type="checkbox" checked="@pg.Enabled"
                                           data-key="@pg.Key" id="pg-@pg.Key" />
                                    <label class="form-check-label fw-semibold" for="pg-@pg.Key">
                                        @(string.IsNullOrEmpty(pg.Label)
                                            ? (HBCDirectory.Models.PdfSettings.KeyLabels.TryGetValue(pg.Key, out var fb) ? fb : pg.Key)
                                            : pg.Label)
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                    <input type="hidden" name="pagesJson" id="pdfPagesJsonInput" />
                    <input type="hidden" name="removePassword" id="removePasswordInput" value="false" />

                    <!-- Password -->
                    <div class="mt-3 pt-3" style="border-top:0.5px solid var(--dir-light2);">
                        <label class="form-label">
                            <i class="fa-solid fa-lock me-1"></i>PDF Password
                        </label>
                        @if (Model.PdfConfig.HasPassword)
                        {
                            <div class="d-flex gap-2 align-items-center mb-2">
                                <span class="text-muted small">
                                    <i class="fa-solid fa-check me-1" style="color:#4a6741;"></i>
                                    Password is set
                                </span>
                                <button type="button" class="btn btn-xs btn-outline-danger"
                                        onclick="clearPdfPassword()">Remove password</button>
                            </div>
                        }
                        <div class="input-group">
                            <input name="password" type="password" class="form-control"
                                   id="pdfPasswordInput"
                                   placeholder="@(Model.PdfConfig.HasPassword ? "Enter new password to change..." : "Set a password (optional)...")" />
                            <button type="button" class="btn btn-outline-secondary"
                                    onclick="togglePdfPasswordVisibility()">
                                <i class="fa-solid fa-eye" id="pdfPwEyeIcon"></i>
                            </button>
                        </div>
                        <p class="text-muted small mt-1">
                            Leave blank to keep current setting.
                        </p>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm mt-3"
                            onclick="buildPagesJson()">
                        <i class="fa-solid fa-floppy-disk me-1"></i>Save settings
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-5">
            <div class="form-card h-100">
                <h6 class="form-card-title">
                    <i class="fa-solid fa-circle-question me-1"></i>How it works
                </h6>
                <p class="text-muted small">
                    The PDF is generated and stored securely in Cloudflare R2.
                    Members download the stored version instantly — no wait time.
                </p>
                <ol class="text-muted small" style="padding-left:1.2rem;">
                    <li class="mb-2">Configure which pages to include and their order above</li>
                    <li class="mb-2">Optionally set a password for the PDF</li>
                    <li class="mb-2">Click <strong>Save settings</strong></li>
                    <li class="mb-2">Click <strong>Update PDF</strong> to generate and store the new version</li>
                    <li>Members can download immediately from the directory</li>
                </ol>
                <div style="background:#fff8e6;border:0.5px solid #e8c97a;border-radius:6px;padding:10px 12px;font-size:12px;color:#a07830;">
                    <i class="fa-solid fa-triangle-exclamation me-1"></i>
                    After adding new members or making significant changes, click <strong>Update PDF</strong>
                    so the stored copy stays current.
                </div>
            </div>
        </div>
    </div>
</div>

@* Drag-and-drop page ordering + form builder *@
<style>
.pdf-page-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  background: white;
  border: 0.5px solid var(--dir-light2);
  border-radius: 6px;
  margin-bottom: 6px;
  transition: background 0.15s, opacity 0.15s, transform 0.1s;
}
.pdf-page-row:hover { background: #fafaf8; }
.pdf-page-drag {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #aaa;
  cursor: grab;
  touch-action: none;
}
.pdf-page-drag:active { cursor: grabbing; }
.pdf-page-row--dragging {
  opacity: 0.4;
}
.pdf-page-row--drag-over {
  border-top: 2px solid var(--dir-mustard);
}
.pdf-page-order {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--dir-dark);
  color: var(--dir-mustard);
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
</style>

<script>
// Drag-and-drop page reordering
let draggedRow = null;

function initPdfPageDrag() {
    document.querySelectorAll('#pdfPagesList .pdf-page-row').forEach(row => {
        const handle = row.querySelector('.pdf-page-drag');
        if (handle) {
            handle.addEventListener('mousedown', () => row.setAttribute('draggable', 'true'));
            handle.addEventListener('touchstart', () => row.setAttribute('draggable', 'true'), { passive: true });
        }
        row.addEventListener('mouseup', () => row.setAttribute('draggable', 'false'));

        row.addEventListener('dragstart', e => {
            draggedRow = row;
            row.classList.add('pdf-page-row--dragging');
            e.dataTransfer.effectAllowed = 'move';
        });

        row.addEventListener('dragend', () => {
            row.classList.remove('pdf-page-row--dragging');
            row.setAttribute('draggable', 'false');
            document.querySelectorAll('#pdfPagesList .pdf-page-row').forEach(r =>
                r.classList.remove('pdf-page-row--drag-over'));
            draggedRow = null;
            updateOrderNumbers();
        });

        row.addEventListener('dragover', e => {
            e.preventDefault();
            if (!draggedRow || draggedRow === row) return;
            e.dataTransfer.dropEffect = 'move';

            const rect     = row.getBoundingClientRect();
            const before   = (e.clientY - rect.top) < rect.height / 2;
            row.parentNode.insertBefore(draggedRow, before ? row : row.nextSibling);
        });

        row.addEventListener('dragenter', e => {
            e.preventDefault();
            if (draggedRow && draggedRow !== row) row.classList.add('pdf-page-row--drag-over');
        });

        row.addEventListener('dragleave', () => {
            row.classList.remove('pdf-page-row--drag-over');
        });

        row.addEventListener('drop', e => {
            e.preventDefault();
            row.classList.remove('pdf-page-row--drag-over');
        });
    });
}

function updateOrderNumbers() {
    document.querySelectorAll('#pdfPagesList .pdf-page-row').forEach((row, i) => {
        const num = row.querySelector('.pdf-page-order');
        if (num) num.textContent = i + 1;
    });
}

// Init on page load
document.addEventListener('DOMContentLoaded', initPdfPageDrag);

function buildPagesJson() {
    const rows  = document.querySelectorAll('#pdfPagesList .pdf-page-row');
    const pages = Array.from(rows).map((row, i) => ({
        key:     row.getAttribute('data-key'),
        label:   row.querySelector('label').textContent.trim(),
        enabled: row.querySelector('.pdf-page-check').checked,
        order:   i + 1
    }));
    document.getElementById('pdfPagesJsonInput').value = JSON.stringify(pages);
}

function clearPdfPassword() {
    document.getElementById('removePasswordInput').value = 'true';
    document.getElementById('pdfPasswordInput').value = '';
    buildPagesJson();
    document.getElementById('pdfSettingsForm').submit();
}

function togglePdfPasswordVisibility() {
    const input = document.getElementById('pdfPasswordInput');
    const icon  = document.getElementById('pdfPwEyeIcon');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa-solid fa-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'fa-solid fa-eye';
    }
}
</script>

