<!-- ══════════════════════════════════════════════════════
     PENDING MEMBER UPDATES — DETAILED
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"> Pending Member Updates </h4>
        @if (Model.PendingUpdates.Any())
        {
            <span class="badge bg-warning text-dark ms-2">@Model.PendingUpdates.Count</span>
        }
    </div>
    @if (!Model.PendingUpdates.Any())
    {
        <p class="text-muted">No pending updates. Member profile submissions will appear here.</p>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var p in Model.PendingUpdates)
            {
                    var doc = System.Text.Json.JsonDocument.Parse(p.ChangesJson).RootElement;
                    var member = p.Member;
                    string? propName      = doc.TryGetProperty("name",           out var jn)  ? jn.GetString()         : null;
                    string? propSurname   = doc.TryGetProperty("surname",        out var js)  ? js.GetString()         : null;
                    string? propPhone     = doc.TryGetProperty("phoneNumber",    out var jp)  ? jp.GetString()         : null;
                    string? propAddress   = doc.TryGetProperty("address",       out var jad) ? jad.GetString()        : null;
                    bool?   propShowPhone = doc.TryGetProperty("showPhone",      out var jsp) ? jsp.GetBoolean()       : (bool?)null;
                    bool?   propShowBd    = doc.TryGetProperty("showBirthdate",  out var jsb) ? jsb.GetBoolean()       : (bool?)null;
                    bool?   propShowAnn   = doc.TryGetProperty("showAnniversary",out var jsa) ? jsa.GetBoolean()       : (bool?)null;
                    bool    hasPhoto      = !string.IsNullOrEmpty(p.PendingPhotoFileName);

                    bool nameChanged    = propName    != null && propName    != member.Name;
                    bool surnameChanged = propSurname != null && propSurname != member.Surname;
                    bool phoneChanged   = propPhone   != null && propPhone   != member.PhoneNumber;
                    bool addressChanged = propAddress != null && propAddress != member.Address;
                    bool spChanged      = propShowPhone.HasValue && propShowPhone.Value != member.ShowPhone;
                    bool sbChanged      = propShowBd.HasValue   && propShowBd.Value    != member.ShowBirthdate;
                    bool saChanged      = propShowAnn.HasValue  && propShowAnn.Value   != member.ShowAnniversary;

                <div class="pending-update-card">
                    <!-- Header -->
                    <div class="pending-update-header">
                        <div>
                            <strong>@member.DisplayName</strong>
                            <span class="text-muted ms-2" style="font-size:12px;">
                                Submitted @p.SubmittedAt.ToString("d MMM yyyy") at @p.SubmittedAt.ToString("HH:mm")
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <form method="post" asp-page-handler="ApprovePending">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="fa-solid fa-check me-1"></i>Approve
                                </button>
                            </form>
                            <form method="post" asp-page-handler="RejectPending"
                                  onsubmit="return confirm('Reject this update from @member.DisplayName?')">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark me-1"></i>Reject
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Body: Current vs Proposed -->
                    <div class="pending-update-body">

                        <!-- Current -->
                        <div class="pending-col">
                            <p class="pending-col-label">Current</p>
                            <div class="pending-photo-row">
                                @if (!string.IsNullOrEmpty(member.PhotoFileName))
                                {
                                    <img src="@Model.PhotoUrl(member.PhotoFileName)"
                                         class="pending-photo lightbox-trigger" alt="Current photo"
                                         onclick="openLightbox(this.src, this.alt)" />
                                }
                                else
                                {
                                    <div class="pending-photo-placeholder">@member.Name[0]@member.Surname[0]</div>
                                }
                                @if (hasPhoto)
                                {
                                    <span class="pending-photo-note text-warning">
                                        <i class="fa-solid fa-triangle-exclamation"></i> New photo submitted
                                    </span>
                                }
                            </div>
                            <table class="pending-fields-table">
                                <tr><td class="field-label">Name</td><td>@member.Name</td></tr>
                                <tr><td class="field-label">Surname</td><td>@member.Surname</td></tr>
                                <tr><td class="field-label">Phone</td><td>@(member.PhoneNumber ?? "—")</td></tr>
                                <tr><td class="field-label">Address</td><td>@(member.Address ?? "—")</td></tr>
                                <tr><td class="field-label">Show phone</td><td>@(member.ShowPhone ? "Yes" : "No")</td></tr>
                                <tr><td class="field-label">Show birthday</td><td>@(member.ShowBirthdate ? "Yes" : "No")</td></tr>
                                <tr><td class="field-label">Show anniversary</td><td>@(member.ShowAnniversary ? "Yes" : "No")</td></tr>
                            </table>
                        </div>

                        <!-- Proposed -->
                        <div class="pending-col">
                            <p class="pending-col-label pending-col-label--proposed">Proposed changes</p>
                            <div class="pending-photo-row">
                                @if (hasPhoto)
                                {
                                    <img src="@Model.PhotoUrl(p.PendingPhotoFileName)"
                                         class="pending-photo pending-photo--new lightbox-trigger" alt="Pending photo"
                                         onclick="openLightbox(this.src, this.alt)" />
                                    <span class="pending-photo-note" style="color:var(--dir-mustard);font-size:12px;font-weight:500;">
                                        <i class="fa-solid fa-image"></i> New photo
                                    </span>
                                }
                                else
                                {
                                    <div class="pending-photo-nochange">No change</div>
                                }
                            </div>
                            <table class="pending-fields-table">
                                <tr class="@(nameChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Name</td>
                                    <td>
                                        @(propName ?? member.Name)
                                        @if (nameChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                                <tr class="@(surnameChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Surname</td>
                                    <td>
                                        @(propSurname ?? member.Surname)
                                        @if (surnameChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                                <tr class="@(phoneChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Phone</td>
                                    <td>
                                        @(propPhone ?? member.PhoneNumber ?? "—")
                                        @if (phoneChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                                <tr class="@(addressChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Address</td>
                                    <td>
                                        @(propAddress ?? member.Address ?? "—")
                                        @if (addressChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                                <tr class="@(spChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Show phone</td>
                                    <td>
                                        @(propShowPhone.HasValue ? (propShowPhone.Value ? "Yes" : "No") : (member.ShowPhone ? "Yes" : "No"))
                                        @if (spChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                                <tr class="@(sbChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Show birthday</td>
                                    <td>
                                        @(propShowBd.HasValue ? (propShowBd.Value ? "Yes" : "No") : (member.ShowBirthdate ? "Yes" : "No"))
                                        @if (sbChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                                <tr class="@(saChanged ? "field-changed" : "field-unchanged")">
                                    <td class="field-label">Show anniversary</td>
                                    <td>
                                        @(propShowAnn.HasValue ? (propShowAnn.Value ? "Yes" : "No") : (member.ShowAnniversary ? "Yes" : "No"))
                                        @if (saChanged) { <span class="changed-tag"><i class="fa-solid fa-arrow-right"></i></span> }
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ══════════════════════════════════════════════════════
     PENDING FAMILY PHOTOS — submitted by a family's designated head via
     their own Profile page; always require approval, no setting to skip.
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Pending Family Photos</h4>
        @if (Model.PendingFamilyPhotos.Any())
        {
            <span class="badge bg-warning text-dark ms-2">@Model.PendingFamilyPhotos.Count</span>
        }
    </div>
    @if (!Model.PendingFamilyPhotos.Any())
    {
        <p class="text-muted">No pending family photos. Submissions from a family's head appear here.</p>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var p in Model.PendingFamilyPhotos)
            {
                var family = p.Family;
                <div class="pending-update-card">
                    <div class="pending-update-header">
                        <div>
                            <strong>@family.FamilyName</strong>
                            <span class="text-muted ms-2" style="font-size:12px;">
                                Submitted @p.SubmittedAt.ToString("d MMM yyyy") at @p.SubmittedAt.ToString("HH:mm")
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <form method="post" asp-page-handler="ApprovePendingFamilyPhoto">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="fa-solid fa-check me-1"></i>Approve
                                </button>
                            </form>
                            <form method="post" asp-page-handler="RejectPendingFamilyPhoto"
                                  onsubmit="return confirm('Reject this photo submission for @family.FamilyName?')">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark me-1"></i>Reject
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="pending-update-body">
                        <div class="pending-col">
                            <p class="pending-col-label">Current</p>
                            <div class="pending-photo-row">
                                @if (!string.IsNullOrEmpty(family.PhotoFileName))
                                {
                                    <img src="@Model.PhotoUrl(family.PhotoFileName)"
                                         class="pending-photo lightbox-trigger" alt="Current family photo"
                                         onclick="openLightbox(this.src, this.alt)" />
                                }
                                else
                                {
                                    <div class="pending-photo-placeholder">@family.FamilyName[0]</div>
                                }
                            </div>
                        </div>
                        <div class="pending-col">
                            <p class="pending-col-label pending-col-label--proposed">Proposed</p>
                            <div class="pending-photo-row">
                                <img src="@Model.PhotoUrl(p.PendingPhotoFileName)"
                                     class="pending-photo pending-photo--new lightbox-trigger" alt="Proposed family photo"
                                     onclick="openLightbox(this.src, this.alt)" />
                                <span class="pending-photo-note" style="color:var(--dir-mustard);font-size:12px;font-weight:500;">
                                    <i class="fa-solid fa-image"></i> New photo
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ══════════════════════════════════════════════════════
     CHANGE HISTORY (Audit Log)
════════════════════════════════════════════════════════ -->
<div class="admin-section mb-5">
<div class="admin-section-header mb-3">
    <h4 class="mb-0">Recent Changes</h4>
</div>
    @if (!Model.RecentChanges.Any())
    {
        <p class="text-muted">No changes recorded yet. Actions will appear here once LogChangeAsync is wired up.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Who</th>
                        <th>What</th>
                        <th>Action</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.RecentChanges)
                    {
                        <tr>
                            <td class="text-muted small">@c.ChangedAt.ToString("d MMM HH:mm")</td>
                            <td class="small">@c.ChangedBy</td>
                            <td>@c.EntityName <span class="text-muted small">(@c.EntityType)</span></td>
                            <td>
                                <span class="badge @(c.Action == "Deleted" ? "bg-danger" : c.Action == "Created" ? "bg-success" : "bg-secondary")">
                                    @c.Action
                                </span>
                            </td>
                            <td class="text-muted small">@c.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

