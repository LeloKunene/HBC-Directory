@page
@model HBCDirectory.Pages.MemberManagement.IndexModel
@{
    ViewData["Title"] = "Member Management | ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title">Member Management</h2>
</div>

<p class="text-muted mb-4">
    Leadership-only. Member statuses (Resigned, Pending Discipline, etc.) and
    Care Groups will land here in follow-up updates — for now, this covers
    roles and who holds them.
</p>

<div class="row g-4">
    <!-- ── Roles & assignments ─────────────────────────────────────── -->
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="card-header">Current role assignments</div>
            <div class="card-body">
            @if (!Model.Assignments.Any())
            {
                <p class="text-muted">Nobody has been granted a role yet.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead>
                        <tr><th>Member</th><th>Role</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.Assignments)
                        {
                            <tr>
                                <td>@a.Member.DisplayName</td>
                                <td><span class="badge bg-dark">@a.Role.Name</span></td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="RevokeRole" class="d-inline"
                                          onsubmit="return confirm('Remove the \'@a.Role.Name\' role from @a.Member.DisplayName?')">
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <button type="submit" class="btn btn-xs btn-outline-danger">Revoke</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            </div>
        </div>

        <div class="admin-card mt-4">
            <div class="card-header">Grant a role</div>
            <div class="card-body">
            <form method="post" asp-page-handler="AssignRole" class="d-flex gap-2 flex-wrap align-items-end">
                <div class="form-field" style="min-width:220px;">
                    <label class="form-label">Member</label>
                    <select name="memberId" class="form-select" required>
                        <option value="" disabled selected>Choose a member…</option>
                        @foreach (var m in Model.AllMembers)
                        {
                            <option value="@m.Id">@m.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="form-field" style="min-width:160px;">
                    <label class="form-label">Role</label>
                    <select name="roleId" class="form-select" required>
                        <option value="" disabled selected>Choose a role…</option>
                        @foreach (var r in Model.Roles)
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Grant</button>
            </form>
            </div>
        </div>
    </div>

    <!-- ── Manage the role list itself ─────────────────────────────── -->
    <div class="col-lg-5">
        <div class="admin-card">
            <div class="card-header">Roles</div>
            <div class="card-body">
            <ul class="list-unstyled mb-3">
                @foreach (var r in Model.Roles)
                {
                    <li class="mb-1">
                        <span class="badge bg-dark">@r.Name</span>
                        @if (r.Name is "Admin" or "Leadership")
                        {
                            <span class="text-muted small ms-1">— built-in, controls actual access</span>
                        }
                    </li>
                }
            </ul>
            <form method="post" asp-page-handler="AddRole" class="d-flex gap-2">
                <input name="roleName" class="form-control form-control-sm"
                       placeholder="e.g. Finance, Youth Leader" required />
                <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">Add role</button>
            </form>
            <p class="text-muted small mt-2 mb-0">
                A new role here is just a label until it's wired up to control
                something specific — "Admin" and "Leadership" are the only two
                that currently grant real access.
            </p>
            </div>
        </div>
    </div>
</div>
